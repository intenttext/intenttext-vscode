{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "IntentText",
  "scopeName": "source.intenttext",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#template-variable"
    },
    {
      "include": "#code-block"
    },
    {
      "include": "#divider"
    },
    {
      "include": "#keyword-line"
    },
    {
      "include": "#property-separator"
    },
    {
      "include": "#inline-formatting"
    }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*//.*$",
      "name": "comment.line.double-slash.intenttext"
    },
    "template-variable": {
      "match": "\\{\\{\\s*[\\w.]+\\s*\\}\\}",
      "name": "variable.other.template.intenttext"
    },
    "code-block": {
      "begin": "^(code)(:)\\s*```\\s*$",
      "end": "^```(.*)$",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.code.intenttext"
        },
        "2": {
          "name": "punctuation.separator.intenttext"
        }
      },
      "endCaptures": {
        "0": {
          "name": "keyword.control.code.intenttext"
        }
      },
      "contentName": "meta.embedded.block.code.intenttext"
    },
    "divider": {
      "match": "^---\\s*$",
      "name": "markup.separator.intenttext"
    },
    "keyword-line": {
      "patterns": [
        {
          "include": "#keyword-title"
        },
        {
          "include": "#keyword-section"
        },
        {
          "include": "#keyword-trust"
        },
        {
          "include": "#keyword-agentic"
        },
        {
          "include": "#keyword-callout"
        },
        {
          "include": "#keyword-task"
        },
        {
          "include": "#keyword-content"
        },
        {
          "include": "#keyword-docgen"
        },
        {
          "include": "#keyword-metadata"
        }
      ]
    },
    "keyword-trust": {
      "patterns": [
        {
          "match": "^(track)(:)\\s*(.*)",
          "captures": {
            "1": {
              "name": "keyword.control.title.intenttext"
            },
            "2": {
              "name": "punctuation.separator.intenttext"
            },
            "3": {
              "name": "string.unquoted.content.intenttext",
              "patterns": [
                {
                  "include": "#template-variable"
                }
              ]
            }
          }
        },
        {
          "match": "^(sign)(:)\\s*(.*)",
          "captures": {
            "1": {
              "name": "markup.bold.trust.sign.intenttext"
            },
            "2": {
              "name": "punctuation.separator.intenttext"
            },
            "3": {
              "name": "string.unquoted.content.intenttext",
              "patterns": [
                {
                  "include": "#template-variable"
                }
              ]
            }
          }
        },
        {
          "match": "^(approve)(:)\\s*(.*)",
          "captures": {
            "1": {
              "name": "markup.inserted.trust.approve.intenttext"
            },
            "2": {
              "name": "punctuation.separator.intenttext"
            },
            "3": {
              "name": "string.unquoted.content.intenttext",
              "patterns": [
                {
                  "include": "#template-variable"
                }
              ]
            }
          }
        },
        {
          "match": "^(freeze)(:)\\s*(.*)",
          "captures": {
            "1": {
              "name": "markup.deleted.trust.freeze.intenttext"
            },
            "2": {
              "name": "punctuation.separator.intenttext"
            },
            "3": {
              "name": "string.unquoted.content.intenttext",
              "patterns": [
                {
                  "include": "#template-variable"
                }
              ]
            }
          }
        },
        {
          "match": "^(revision)(:)\\s*(.*)",
          "captures": {
            "1": {
              "name": "comment.block.trust.revision.intenttext"
            },
            "2": {
              "name": "punctuation.separator.intenttext"
            },
            "3": {
              "name": "comment.block.trust.revision.intenttext"
            }
          }
        },
        {
          "match": "^(amendment|amend|change)(:)\\s*(.*)",
          "captures": {
            "1": {
              "name": "markup.bold.trust.amendment.intenttext"
            },
            "2": {
              "name": "punctuation.separator.intenttext"
            },
            "3": {
              "name": "string.unquoted.content.intenttext",
              "patterns": [
                {
                  "include": "#template-variable"
                }
              ]
            }
          }
        },
        {
          "match": "^(history)(:)\\s*(.*)",
          "captures": {
            "1": {
              "name": "comment.block.trust.history.intenttext"
            },
            "2": {
              "name": "punctuation.separator.intenttext"
            },
            "3": {
              "name": "comment.block.trust.history.intenttext"
            }
          }
        }
      ]
    },
    "keyword-title": {
      "match": "^(title|summary)(:)\\s*(.*)",
      "captures": {
        "1": {
          "name": "keyword.control.title.intenttext"
        },
        "2": {
          "name": "punctuation.separator.intenttext"
        },
        "3": {
          "name": "markup.heading.intenttext",
          "patterns": [
            {
              "include": "#template-variable"
            }
          ]
        }
      }
    },
    "keyword-section": {
      "match": "^(section|sub|subsection|deadline|due|milestone|due-date)(:)\\s*(.*)",
      "captures": {
        "1": {
          "name": "keyword.control.section.intenttext"
        },
        "2": {
          "name": "punctuation.separator.intenttext"
        },
        "3": {
          "name": "markup.heading.section.intenttext",
          "patterns": [
            {
              "include": "#template-variable"
            }
          ]
        }
      }
    },
    "keyword-agentic": {
      "match": "^(step|decision|trigger|loop|checkpoint|audit|error|import|export|progress|context|result|handoff|wait|parallel|retry|gate|call|emit|signal|memory|prompt|tool|assert|secret)(:)\\s*(.*)",
      "captures": {
        "1": {
          "name": "entity.name.function.agentic.intenttext"
        },
        "2": {
          "name": "punctuation.separator.intenttext"
        },
        "3": {
          "name": "string.unquoted.content.intenttext",
          "patterns": [
            {
              "include": "#template-variable"
            }
          ]
        }
      }
    },
    "keyword-callout": {
      "match": "^(text|note|info|warning|danger|tip|success|cite)(:)\\s*(.*)",
      "captures": {
        "1": {
          "name": "markup.italic.callout.intenttext"
        },
        "2": {
          "name": "punctuation.separator.intenttext"
        },
        "3": {
          "name": "string.unquoted.content.intenttext",
          "patterns": [
            {
              "include": "#template-variable"
            }
          ]
        }
      }
    },
    "keyword-task": {
      "match": "^(task|done|ask|question)(:)\\s*(.*)",
      "captures": {
        "1": {
          "name": "variable.other.task.intenttext"
        },
        "2": {
          "name": "punctuation.separator.intenttext"
        },
        "3": {
          "name": "string.unquoted.content.intenttext",
          "patterns": [
            {
              "include": "#template-variable"
            }
          ]
        }
      }
    },
    "keyword-content": {
      "match": "^(quote|image|link|ref|embed|code|columns|headers|row|def|define|term|glossary|figure|fig|diagram|chart|contact|person|party|input|output)(:)\\s*(.*)",
      "captures": {
        "1": {
          "name": "support.type.content.intenttext"
        },
        "2": {
          "name": "punctuation.separator.intenttext"
        },
        "3": {
          "name": "string.unquoted.content.intenttext",
          "patterns": [
            {
              "include": "#template-variable"
            }
          ]
        }
      }
    },
    "keyword-docgen": {
      "match": "^(font|page|break|byline|epigraph|caption|footnote|toc|dedication|signline|signature-line|sign-here|sig)(:)\\s*(.*)",
      "captures": {
        "1": {
          "name": "storage.type.docgen.intenttext"
        },
        "2": {
          "name": "punctuation.separator.intenttext"
        },
        "3": {
          "name": "string.unquoted.content.intenttext",
          "patterns": [
            {
              "include": "#template-variable"
            }
          ]
        }
      }
    },
    "keyword-metadata": {
      "match": "^(agent|model|status|metric|kpi|measure|stat|meta)(:)\\s*(.*)",
      "captures": {
        "1": {
          "name": "constant.language.metadata.intenttext"
        },
        "2": {
          "name": "punctuation.separator.intenttext"
        },
        "3": {
          "name": "string.unquoted.content.intenttext",
          "patterns": [
            {
              "include": "#template-variable"
            }
          ]
        }
      }
    },
    "property-separator": {
      "match": "\\|",
      "name": "punctuation.separator.pipe.intenttext"
    },
    "inline-formatting": {
      "patterns": [
        {
          "match": "\\*\\*([^*]+)\\*\\*",
          "name": "markup.bold.intenttext"
        },
        {
          "match": "(?<!\\*)\\*([^*]+)\\*(?!\\*)",
          "name": "markup.italic.intenttext"
        },
        {
          "match": "~([^~]+)~",
          "name": "markup.strikethrough.intenttext"
        },
        {
          "match": "`([^`]+)`",
          "name": "markup.inline.raw.intenttext"
        },
        {
          "match": "==([^=]+)==",
          "name": "markup.highlight.intenttext"
        },
        {
          "match": "@\\w+",
          "name": "entity.name.tag.mention.intenttext"
        },
        {
          "match": "#\\w+",
          "name": "entity.name.tag.hashtag.intenttext"
        },
        {
          "match": "\\[\\^\\d+\\]",
          "name": "constant.other.footnote-ref.intenttext"
        }
      ]
    }
  }
}