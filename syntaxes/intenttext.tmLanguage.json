{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "IntentText",
  "scopeName": "source.intenttext",
  "patterns": [
    { "include": "#comment" },
    { "include": "#template-variable" },
    { "include": "#code-block" },
    { "include": "#divider" },
    { "include": "#keyword-line" },
    { "include": "#property-separator" },
    { "include": "#inline-formatting" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*//.*$",
      "name": "comment.line.double-slash.intenttext"
    },
    "template-variable": {
      "match": "\\{\\{\\s*[\\w.]+\\s*\\}\\}",
      "name": "variable.other.template.intenttext"
    },
    "code-block": {
      "begin": "^code:.*$",
      "end": "^end:.*$",
      "beginCaptures": {
        "0": { "name": "keyword.control.code.intenttext" }
      },
      "endCaptures": {
        "0": { "name": "keyword.control.end.intenttext" }
      },
      "contentName": "meta.embedded.block.code.intenttext"
    },
    "divider": {
      "match": "^---\\s*$",
      "name": "markup.separator.intenttext"
    },
    "keyword-line": {
      "patterns": [
        { "include": "#keyword-title" },
        { "include": "#keyword-section" },
        { "include": "#keyword-agentic" },
        { "include": "#keyword-callout" },
        { "include": "#keyword-task" },
        { "include": "#keyword-content" },
        { "include": "#keyword-docgen" },
        { "include": "#keyword-metadata" }
      ]
    },
    "keyword-title": {
      "match": "^(title|summary)(:)\\s*(.*)",
      "captures": {
        "1": { "name": "keyword.control.title.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "markup.heading.intenttext" }
      }
    },
    "keyword-section": {
      "match": "^(section|sub|subsection)(:)\\s*(.*)",
      "captures": {
        "1": { "name": "keyword.control.section.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "markup.heading.section.intenttext" }
      }
    },
    "keyword-agentic": {
      "match": "^(step|decision|trigger|loop|checkpoint|audit|error|import|export|progress|context|result|handoff|wait|parallel|retry|gate|call|emit)(:)\\s*(.*)",
      "captures": {
        "1": { "name": "entity.name.function.agentic.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "string.unquoted.content.intenttext" }
      }
    },
    "keyword-callout": {
      "match": "^(note|info|warning|tip|success)(:)\\s*(.*)",
      "captures": {
        "1": { "name": "markup.italic.callout.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "string.unquoted.content.intenttext" }
      }
    },
    "keyword-task": {
      "match": "^(task|done|ask|question)(:)\\s*(.*)",
      "captures": {
        "1": { "name": "variable.other.task.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "string.unquoted.content.intenttext" }
      }
    },
    "keyword-content": {
      "match": "^(quote|image|link|ref|embed|code|end|headers|row)(:)\\s*(.*)",
      "captures": {
        "1": { "name": "support.type.content.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "string.unquoted.content.intenttext" }
      }
    },
    "keyword-docgen": {
      "match": "^(font|page|break|byline|epigraph|caption|footnote|toc|dedication)(:)\\s*(.*)",
      "captures": {
        "1": { "name": "storage.type.docgen.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "string.unquoted.content.intenttext" }
      }
    },
    "keyword-metadata": {
      "match": "^(agent|model|status)(:)\\s*(.*)",
      "captures": {
        "1": { "name": "constant.language.metadata.intenttext" },
        "2": { "name": "punctuation.separator.intenttext" },
        "3": { "name": "string.unquoted.content.intenttext" }
      }
    },
    "property-separator": {
      "match": "\\|",
      "name": "punctuation.separator.pipe.intenttext"
    },
    "inline-formatting": {
      "patterns": [
        {
          "match": "\\*\\*([^*]+)\\*\\*",
          "name": "markup.bold.intenttext"
        },
        {
          "match": "(?<!\\*)\\*([^*]+)\\*(?!\\*)",
          "name": "markup.italic.intenttext"
        },
        {
          "match": "~~([^~]+)~~",
          "name": "markup.strikethrough.intenttext"
        },
        {
          "match": "`([^`]+)`",
          "name": "markup.inline.raw.intenttext"
        },
        {
          "match": "==([^=]+)==",
          "name": "markup.highlight.intenttext"
        },
        {
          "match": "@\\w+",
          "name": "entity.name.tag.mention.intenttext"
        },
        {
          "match": "#\\w+",
          "name": "entity.name.tag.hashtag.intenttext"
        },
        {
          "match": "\\[\\^\\d+\\]",
          "name": "constant.other.footnote-ref.intenttext"
        }
      ]
    }
  }
}
